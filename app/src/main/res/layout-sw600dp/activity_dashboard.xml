                    <TextView
                        android:id="@+id/tvPlantLeftLabel"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardPlantRight"
                    android:layout_width="1dp"
                    android:layout_height="1dp">

                    <ImageView
                        android:id="@+id/imgPlantRight"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantRightTime"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantRightStatus"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantRightLabel"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardPlantHp"
                    android:layout_width="1dp"
                    android:layout_height="1dp">

                    <ImageView
                        android:id="@+id/imgPlantHp"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantHpTime"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantHpStatus"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/tvPlantHpLabel"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

