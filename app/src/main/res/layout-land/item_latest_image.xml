<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:orientation="horizontal">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="6dp"
        android:layout_weight="1"
        android:background="@drawable/bg_latest_photo_round"
        android:clipToOutline="true">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgLatestItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_latest_photo_round"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/plant"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Penyakitan.LatestPhoto" />

        <TextView
            android:id="@+id/tvLatestItemLabel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_badge_white"
            android:gravity="center"
            android:maxWidth="260dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:text="Memuat Foto..."
            android:textColor="#245D23"
            android:textSize="13sp"
            android:textStyle="bold" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/containerLatestItemSecond"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_weight="1"
        android:background="@drawable/bg_latest_photo_round"
        android:clipToOutline="true">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgLatestItemSecond"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_latest_photo_round"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/plant"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Penyakitan.LatestPhoto" />

        <TextView
            android:id="@+id/tvLatestItemSecondLabel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_badge_white"
            android:gravity="center"
            android:maxWidth="260dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:text="Memuat Foto..."
            android:textColor="#245D23"
            android:textSize="13sp"
            android:textStyle="bold" />

    </FrameLayout>

</LinearLayout>
