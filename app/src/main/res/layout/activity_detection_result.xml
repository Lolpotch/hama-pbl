<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- FOTO HASIL SHOOT -->
        <ImageView
            android:id="@+id/imgResult"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD" />

        <!-- STATUS -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:padding="12dp"
            android:text="Menunggu hasil inference..."
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- CARD HASIL PENYAKIT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Penyakit"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDiseaseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Nama Penyakit: -"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDiseaseConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Confidence: -"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDiseaseDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Deskripsi: -"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDiseaseSolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Solusi: -"
                android:textColor="#444444"
                android:textSize="14sp"
                android:textStyle="italic" />

        </LinearLayout>

        <!-- CARD HASIL HAMA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Hama"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPestName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Nama Hama: -"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPestConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Confidence: -"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtPestSolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Solusi: -"
                android:textColor="#444444"
                android:textSize="14sp"
                android:textStyle="italic" />

        </LinearLayout>

        <!-- RESPONSE RAW OPSIONAL -->
        <TextView
            android:id="@+id/txtRawResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_white"
            android:padding="12dp"
            android:text="Raw response akan tampil di sini jika diperlukan."
            android:textColor="#777777"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- TOMBOL TUTUP -->
        <Button
            android:id="@+id/btnClose"
            android:text="Tutup"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>