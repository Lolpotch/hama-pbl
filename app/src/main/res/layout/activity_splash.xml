<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FAF4">

    <!-- Background selada -->
    <ImageView
        android:id="@+id/imgSplashBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:scaleType="centerCrop"
        android:src="@drawable/lettuce" />

    <!-- Overlay putih kehijauan -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B8F6FAF4" />

    <!-- Logo kecil bagian atas -->
    <LinearLayout
        android:id="@+id/topLogoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="34dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgTopLogoLeft"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/pnj" />

        <ImageView
            android:id="@+id/imgTopLogoRight"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="30dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/unnamed" />

    </LinearLayout>

    <!-- Logo utama tengah -->
    <LinearLayout
        android:id="@+id/mainSplashContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/imgSplashLogo"
            android:layout_width="260dp"
            android:layout_height="220dp"
            android:alpha="0"
            android:scaleX="0.75"
            android:scaleY="0.75"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/mipmap03" />

        <ImageView
            android:id="@+id/imgSplashText"
            android:layout_width="260dp"
            android:layout_height="70dp"
            android:layout_marginTop="8dp"
            android:alpha="0"
            android:translationY="25dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/mipmap06" />

    </LinearLayout>

    <!-- Loading bawah -->
    <FrameLayout
        android:id="@+id/loadingTrack"
        android:layout_width="170dp"
        android:layout_height="5dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="64dp"
        android:background="@drawable/bg_splash_line_track">

        <View
            android:id="@+id/viewLoadingLine"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_splash_line" />

    </FrameLayout>

</FrameLayout>