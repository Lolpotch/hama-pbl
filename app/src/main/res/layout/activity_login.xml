<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FAF4">

    <!-- Dekorasi daun transparan kiri bawah -->
    <ImageView
        android:layout_width="210dp"
        android:layout_height="210dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-70dp"
        android:layout_marginBottom="30dp"
        android:alpha="0.07"
        android:scaleType="fitCenter"
        android:src="@drawable/leaf" />

    <!-- Dekorasi daun transparan kanan tengah -->
    <ImageView
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="-65dp"
        android:alpha="0.07"
        android:scaleType="fitCenter"
        android:src="@drawable/leaf" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F6FAF4"
            android:orientation="vertical">

            <!-- HEADER HIJAU ATAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="@drawable/bg_login_header_green"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <ImageView
                    android:id="@+id/imgLoginLogo"
                    android:layout_width="310dp"
                    android:layout_height="82dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mipmap10" />

                <TextView
                    android:id="@+id/tvLoginSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Deteksi Hama dan Penyakit pada Tanaman Selada"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- AREA LOGIN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="68dp"
                android:layout_marginEnd="34dp"
                android:orientation="vertical">

                <!-- Judul dibuat lebih naik -->
                <TextView
                    android:id="@+id/tvWelcomeBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang"
                    android:textColor="#245D23"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLoginDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Masuk untuk memantau kondisi tanaman dan hasil deteksi terbaru."
                    android:textColor="#6A7F6A"
                    android:textSize="13sp" />

                <!-- EMAIL GARIS BAWAH -->
                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="42dp"
                    android:background="@drawable/bg_login_underline"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:singleLine="true"
                    android:textColor="#245D23"
                    android:textColorHint="#8AA08A"
                    android:textSize="15sp" />

                <!-- PASSWORD GARIS BAWAH -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_login_underline">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:paddingStart="4dp"
                        android:paddingEnd="48dp"
                        android:singleLine="true"
                        android:textColor="#245D23"
                        android:textColorHint="#8AA08A"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end|center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@drawable/merem" />

                </FrameLayout>

                <!-- TOMBOL LOGIN -->
                <TextView
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="52dp"
                    android:background="@drawable/bg_login_button_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="Login"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="© 2026 Lokasight"
                    android:textColor="#8CA08C"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>