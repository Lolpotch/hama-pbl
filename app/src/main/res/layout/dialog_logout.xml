<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="22dp">

    <TextView
        android:id="@+id/tvLogoutTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textColor="#1F6B2A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvLogoutMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:text="Apakah Anda yakin ingin keluar dari aplikasi?"
        android:textColor="#667085"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancelLogout"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:minWidth="96dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Batal"
            android:textColor="#667085"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnConfirmLogout"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_login_button_green"
            android:gravity="center"
            android:minWidth="110dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Logout"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>